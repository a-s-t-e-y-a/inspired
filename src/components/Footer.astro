---
const quickLinks = [
	{ name: "Home", href: "/" },
	{ name: "Services", href: "/services" },
	{ name: "About Us", href: "/about" },
	{ name: "Contact Us", href: "/contact" },
];
---

<footer class="bg-white pt-16 pb-8 border-t border-primary/10">
	<div class="container max-w-[1400px] mx-auto px-6 md:px-0">
		<div
			class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12 lg:gap-24 mb-16"
		>
			<!-- Brand Column -->
			<div class="lg:col-span-2">
				<div class="flex items-center mb-8">
					<img
						src="/maditailarLogo.png"
						alt="MediTailor Logo"
						class="h-24 md:h-32 w-auto"
					/>
				</div>
				<p
					class="text-primary text-[14px] leading-relaxed font-[300] mb-8 max-w-[500px]"
				>
					MediTailor provides affordable, world-class medical
					treatments in India for international patients. Combining
					expert surgical guidance with end-to-end concierge support,
					we ensure a safe, transparent, and successful path to
					health.
				</p>

				<div class="flex gap-4 mb-8">
					<a
						href="#"
						class="text-primary hover:scale-110 transition-transform"
					>
						<svg
							xmlns="http://www.w3.org/2000/svg"
							width="22"
							height="22"
							viewBox="0 0 24 24"
							fill="currentColor"
							><path
								d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"
							></path></svg
						>
					</a>
					<a
						href="#"
						class="text-primary hover:scale-110 transition-transform"
					>
						<svg
							xmlns="http://www.w3.org/2000/svg"
							width="22"
							height="22"
							viewBox="0 0 24 24"
							fill="currentColor"
							><path
								d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.246 2.248 3.484 5.232 3.484 8.412s-1.239 6.164-3.488 8.412c-2.248 2.247-5.231 3.487-8.412 3.487h-.001c-2.007 0-3.98-.539-5.717-1.557l-5.789 1.517zm5.666-3.414c1.603.953 3.46 1.457 5.352 1.458h.001c5.452 0 9.891-4.438 9.893-9.891 0-2.641-1.029-5.123-2.895-6.99-1.868-1.868-4.349-2.897-6.99-2.897-5.454 0-9.893 4.439-9.893 9.893 0 1.996.6 3.931 1.734 5.589l-1.042 3.804 3.9-.99-.06-.036zm11.528-6.138c-.301-.15-1.78-.878-2.056-.978-.275-.1-.476-.15-.676.15-.2.3-.775 1.05-.951 1.25-.175.2-.35.225-.651.075-.3-.15-1.267-.467-2.414-1.49-.893-.797-1.493-1.783-1.669-2.083-.175-.3-.018-.462.132-.612.135-.135.3-.35.45-.525.15-.175.2-.3.3-.5.1-.2.05-.375-.025-.525-.075-.15-.676-1.628-.926-2.228-.244-.584-.492-.505-.676-.514l-.576-.013c-.2 0-.525.075-.8.375s-1.05 1.025-1.05 2.5 1.075 2.9 1.225 3.1c.15.2 2.112 3.226 5.118 4.525.715.309 1.274.494 1.71.632.718.228 1.373.196 1.89.118.577-.087 1.781-.728 2.031-1.428.25-.7.25-1.3.175-1.428-.076-.126-.276-.2-.576-.351z"
							></path></svg
						>
					</a>
					<a
						href="#"
						class="text-primary hover:scale-110 transition-transform"
					>
						<svg
							xmlns="http://www.w3.org/2000/svg"
							width="22"
							height="22"
							viewBox="0 0 24 24"
							fill="currentColor"
							><path
								d="M19.615 3.184c-3.604-.246-11.631-.245-15.23 0-3.897.266-4.356 2.62-4.385 8.816.029 6.185.484 8.549 4.385 8.816 3.6.245 11.626.246 15.23 0 3.897-.266 4.356-2.62 4.385-8.816-.029-6.185-.484-8.549-4.385-8.816zm-10.615 12.816v-8l8 4-8 4z"
							></path></svg
						>
					</a>
					<a
						href="#"
						class="text-primary hover:scale-110 transition-transform"
					>
						<svg
							xmlns="http://www.w3.org/2000/svg"
							width="22"
							height="22"
							viewBox="0 0 24 24"
							fill="currentColor"
							><path
								d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"
							></path></svg
						>
					</a>
					<a
						href="#"
						class="text-primary hover:scale-110 transition-transform"
					>
						<svg
							xmlns="http://www.w3.org/2000/svg"
							width="22"
							height="22"
							viewBox="0 0 24 24"
							fill="currentColor"
							><path
								d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
							></path></svg
						>
					</a>
				</div>

				<div class="space-y-4">
					<div class="flex items-center gap-3 text-primary">
						<svg
							xmlns="http://www.w3.org/2000/svg"
							width="18"
							height="18"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="2"
							stroke-linecap="round"
							stroke-linejoin="round"
							><path
								d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l2.27-2.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"
							></path></svg
						>
						<span class="font-medium"
							>Emergency : +91 8595114141</span
						>
					</div>
					<div class="flex items-center gap-3 text-primary">
						<svg
							xmlns="http://www.w3.org/2000/svg"
							width="18"
							height="18"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="2"
							stroke-linecap="round"
							stroke-linejoin="round"
							><rect width="20" height="16" x="2" y="4" rx="2"
							></rect><path
								d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"
							></path></svg
						>
						<span class="font-medium"
							>info.meditailor@gmail.com</span
						>
					</div>
				</div>
			</div>

			<!-- Links Column -->
			<div>
				<h4
					class="text-primary font-bold mb-8 text-[18px] uppercase tracking-wider"
				>
					Links
				</h4>
				<ul class="space-y-5">
					{
						quickLinks.map((link) => (
							<li>
								<a
									href={link.href}
									class="text-primary opacity-90 hover:opacity-100 transition-opacity font-[400] text-[16px]"
								>
									{link.name}
								</a>
							</li>
						))
					}
				</ul>
			</div>
		</div>

		<!-- Bottom Bar -->
		<div
			class="pt-8 border-t border-primary/10 flex flex-col md:flex-row justify-between items-center gap-4 text-center md:text-left"
		>
			<p class="text-primary opacity-80 font-[300] text-[14px]">
				© 2026 Meditailor. All Rights Reserved.
			</p>
			<div class="flex gap-6 items-center">
				<a
					href="#"
					class="text-primary opacity-80 hover:opacity-100 transition-opacity text-[14px] font-[300]"
					>Privacy Policy</a
				>
				<span class="text-primary opacity-30 text-[10px]">|</span>
				<a
					href="#"
					class="text-primary opacity-80 hover:opacity-100 transition-opacity text-[14px] font-[300]"
					>Terms & Conditions</a
				>
			</div>
		</div>
	</div>
</footer>
