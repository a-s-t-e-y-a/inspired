---
const awards = [
  {
    title: "Accredited by NABH & NABL",
    description: "National Accreditation Board for Hospitals & Healthcare Providers",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#FBBF24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-trophy"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/><path d="M4 22h16"/><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"/><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"/><path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"/></svg>`
  },
  {
    title: "Quality & Patient Safety",
    description: "Recognized for excellence in healthcare quality standards",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-shield-check"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/><path d="m9 12 2 2 4-4"/></svg>`
  },
  {
    title: "JCI Accreditation",
    description: "Joint Commission International Certified Hospital",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-medal"><path d="M7.21 15 2.66 7.14a2 2 0 0 1 .13-2.2L4.4 2.8A2 2 0 0 1 6 2h12a2 2 0 0 1 1.6.8l1.6 2.14a2 2 0 0 1 .14 2.2L16.79 15"/><path d="M11 12 5.12 2.2"/><path d="m13 12 5.88-9.8"/><path d="M8 7h8"/><circle cx="12" cy="17" r="5"/><path d="M12 18v-2h.5"/></svg>`
  },
  {
    title: "Operational Excellence",
    description: "Award for operational efficiency and hospital management",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#FBBF24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-star"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>`
  }
];
---

<section class="bg-[#DAE9FF] py-24 px-2 md:px-20 lg:pl-[calc((100%-1200px)/2+4rem)] xl:pl-[calc((100%-1600px)/2+5rem)] xl:pr-[calc((100%-1600px)/2+5rem)]">
	<div class="w-full max-w-[1600px] mx-auto">
		<h2 class="text-[32px] md:text-[40px] font-[400] text-black mb-12 tracking-tight px-4 md:px-0">Awards</h2>

		<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
			{awards.map((award) => (
				<div class="bg-white p-10 rounded-2xl border border-primary/5 shadow-sm flex flex-col items-center text-center group hover:shadow-lg hover:-translate-y-1 transition-all duration-300">
					<div class="mb-8 p-4 bg-gray-50 rounded-2xl group-hover:scale-110 transition-transform duration-300">
						<Fragment set:html={award.icon} />
					</div>
					<h3 class="text-black font-[500] text-lg md:text-xl mb-4 leading-tight">{award.title}</h3>
					<p class="text-gray-500 font-[300] text-sm md:text-base leading-relaxed">
						{award.description}
					</p>
				</div>
			))}
		</div>
	</div>
</section>
