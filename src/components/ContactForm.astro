---
import { Image } from "astro:assets";
import contactImage from "../assets/contact-doctor.png";
---

<section
	id="consultation"
	class="bg-white py-12 md:py-20 mb-8 md:mb-16 px-0 md:px-20 lg:pl-[calc((100%-1200px)/2+4rem)] xl:pl-[calc((100%-1600px)/2+5rem)] xl:pr-[calc((100%-1600px)/2+5rem)]"
>
	<div
		class="w-full max-w-[1600px] mx-auto overflow-hidden rounded-none md:rounded-[2.5rem] shadow-2xl flex flex-col lg:flex-row min-h-[700px]"
	>
		<div class="lg:w-1/2 relative min-h-[400px] lg:min-h-full">
			<Image
				src={contactImage}
				alt="Professional medical doctor with tablet"
				class="absolute inset-0 w-full h-full object-cover grayscale-[0.2] contrast-[1.1]"
			/>
		</div>

		<div class="lg:w-1/2 bg-primary p-8 md:p-12 lg:p-16 flex flex-col">
			<h2
				class="text-white text-[32px] md:text-[40px] font-[300] text-center mb-10 tracking-tight"
			>
				Book Your Consultation
			</h2>

			<form id="contactForm" class="space-y-6">
				<div>
					<label class="block text-white text-sm font-[500] mb-2"
						>Patient Full Name</label
					>
					<input
						id="fullName"
						name="fullName"
						type="text"
						placeholder="Enter patient full name"
						class="w-full bg-white border-none rounded-lg px-4 py-3.5 text-black placeholder:text-gray-400 focus:ring-2 focus:ring-white/20 outline-none invalid:ring-red-500 invalid:ring-2"
					/>
					<p id="fullName-error" class="text-red-400 text-sm mt-1 hidden"></p>
				</div>

				<div>
					<label class="block text-white text-sm font-[500] mb-2"
						>Select Country</label
					>
					<div class="relative">
						<select
							id="country"
							name="country"
							class="w-full bg-white border-none rounded-lg px-4 py-3.5 text-gray-500 appearance-none focus:ring-2 focus:ring-white/20 outline-none invalid:ring-red-500 invalid:ring-2"
						>
							<option value="">Select your country</option>
							<option value="US">United States</option>
							<option value="GB">United Kingdom</option>
							<option value="NG">Nigeria</option>
							<option value="ET">Ethiopia</option>
							<option value="BD">Bangladesh</option>
						</select>
						<div
							class="absolute inset-y-0 right-0 flex items-center px-4 pointer-events-none text-gray-400"
						>
							<svg
								xmlns="http://www.w3.org/2000/svg"
								width="16"
								height="16"
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="2"
								stroke-linecap="round"
								stroke-linejoin="round"
								><path d="m6 9 6 6 6-6"></path></svg
							>
						</div>
					</div>
					<p id="country-error" class="text-red-400 text-sm mt-1 hidden"></p>
				</div>

				<div>
					<label class="block text-white text-sm font-[500] mb-2"
						>Your email id</label
					>
					<input
						id="email"
						name="email"
						type="email"
						placeholder="Enter your email id"
						class="w-full bg-white border-none rounded-lg px-4 py-3.5 text-black placeholder:text-gray-400 focus:ring-2 focus:ring-white/20 outline-none invalid:ring-red-500 invalid:ring-2"
					/>
					<p id="email-error" class="text-red-400 text-sm mt-1 hidden"></p>
				</div>

				<div>
					<label class="block text-white text-sm font-[500] mb-2"
						>Your Phone number</label
					>
					<div class="flex gap-3">
						<div
							class="w-20 bg-white rounded-lg flex items-center justify-center text-gray-600 font-medium text-sm"
						>
							+91
						</div>
						<input
							id="phone"
							name="phone"
							type="tel"
							placeholder="Enter your phone number"
							class="flex-1 bg-white border-none rounded-lg px-4 py-3.5 text-black placeholder:text-gray-400 focus:ring-2 focus:ring-white/20 outline-none invalid:ring-red-500 invalid:ring-2"
						/>
					</div>
					<p id="phone-error" class="text-red-400 text-sm mt-1 hidden"></p>
				</div>

				<div>
					<label class="block text-white text-sm font-[500] mb-2"
						>Upload Medical Document (Optional)</label
					>
					<input
						id="document"
						name="document"
						type="file"
						accept=".pdf,.png,.jpg,.jpeg,.doc,.docx"
						class="w-full bg-white border-none rounded-lg px-4 py-3 text-black placeholder:text-gray-400 focus:ring-2 focus:ring-white/20 outline-none file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-primary/20 file:text-primary hover:file:bg-primary/30 cursor-pointer"
					/>
					<p id="document-error" class="text-red-400 text-sm mt-1 hidden"></p>
				</div>

				<!-- Status Messages -->
				<div id="successMessage" class="hidden bg-green-500/20 border border-green-500 text-green-100 px-4 py-3 rounded-lg text-sm flex items-center gap-2">
					<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg>
					<span>Thank you! Your consultation request has been submitted successfully.</span>
				</div>

				<div id="errorMessage" class="hidden bg-red-500/20 border border-red-500 text-red-100 px-4 py-3 rounded-lg text-sm flex items-center gap-2">
					<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><line x1="12" x2="12" y1="8" y2="12"></line><line x1="12" x2="12.01" y1="16" y2="16"></line></svg>
					<span id="errorText">An error occurred. Please try again.</span>
				</div>

				<div class="pt-4">
					<button
						type="submit"
						id="submitBtn"
						class="w-full bg-white text-primary py-4 rounded-xl font-semibold text-lg shadow-lg active:scale-[0.98] transition-all hover:bg-gray-100 flex items-center justify-center gap-3 disabled:opacity-50 disabled:cursor-not-allowed"
					>
						<span id="submitText">Submit Application</span>
						<svg
							id="submitIcon"
							xmlns="http://www.w3.org/2000/svg"
							width="20"
							height="20"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="2"
							stroke-linecap="round"
							stroke-linejoin="round"
							><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"
							></path></svg
						>
					</button>
				</div>
			</form>
		</div>
	</div>
</section>

<script>
	import { db } from '../utils/supabase';
	import { validateContactForm } from '../utils/validation';

	console.log('📋 ContactForm script loaded');

	const form = document.getElementById('contactForm') as HTMLFormElement;
	const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement;
	const submitText = document.getElementById('submitText') as HTMLElement;
	const submitIcon = document.getElementById('submitIcon') as HTMLElement;
	const successMessage = document.getElementById('successMessage') as HTMLElement;
	const errorMessage = document.getElementById('errorMessage') as HTMLElement;
	const errorText = document.getElementById('errorText') as HTMLElement;

	console.log('✅ ContactForm elements found:', { form: !!form, submitBtn: !!submitBtn });

	if (form) {
		form.addEventListener('submit', async (e) => {
			e.preventDefault();
			console.log('📤 Form submit event triggered');

			// Get form values
			const fullNameInput = document.getElementById('fullName') as HTMLInputElement;
			const countryInput = document.getElementById('country') as HTMLSelectElement;
			const emailInput = document.getElementById('email') as HTMLInputElement;
			const phoneInput = document.getElementById('phone') as HTMLInputElement;
			const documentInput = document.getElementById('document') as HTMLInputElement;

			const formData = {
				fullName: fullNameInput.value,
				country: countryInput.value,
				email: emailInput.value,
				phone: phoneInput.value,
			};

			console.log('📋 Form data collected:', { ...formData, hasDocument: documentInput.files && documentInput.files.length > 0 });

			// Clear previous messages
			successMessage.classList.add('hidden');
			errorMessage.classList.add('hidden');

			// Validate form
			console.log('🔍 Validating form data...');
			const validation = validateContactForm(formData);
			console.log('✅ Validation result:', { isValid: validation.isValid, errors: validation.errors });

			if (!validation.isValid) {
				console.log('❌ Validation failed. Displaying errors...');
				// Display errors
				validation.errors.forEach((error) => {
					console.log(`   - ${error.field}: ${error.message}`);
					const errorElement = document.getElementById(`${error.field}-error`) as HTMLElement;
					if (errorElement) {
						errorElement.textContent = error.message;
						errorElement.classList.remove('hidden');
					}
				});
				return;
			}

			console.log('✅ Validation passed!');

			// Clear error messages
			document.querySelectorAll('[id$="-error"]').forEach((el) => {
				el.classList.add('hidden');
			});

			// Disable button and show loading state
			submitBtn.disabled = true;
			submitText.textContent = 'Submitting...';
			submitIcon.classList.add('animate-spin');
			console.log('⏳ Submission started, button disabled');

			try {
				let documentUrl = undefined;
				
				// Handle file upload if present
				if (documentInput && documentInput.files && documentInput.files.length > 0) {
					console.log('📄 Uploading document first...');
					const file = documentInput.files[0];
					
					// Basic file size check (< 5MB)
					if (file.size > 5 * 1024 * 1024) {
						throw new Error('File size exceeds 5MB limit. Please upload a smaller file.');
					}
					
					submitText.textContent = 'Uploading Document...';
					documentUrl = await db.uploadMedicalDocument(file);
				}

				// Insert contact into Supabase
				console.log('🚀 Calling db.insertContact...');
				submitText.textContent = 'Saving Details...';
				const contact = await db.insertContact({
					full_name: formData.fullName,
					country: formData.country,
					email: formData.email,
					phone: formData.phone,
					source: 'contact_form',
					document_url: documentUrl,
				});

				console.log('✅ Contact submitted successfully:', contact);

				// Show success message
				successMessage.classList.remove('hidden');
				console.log('✅ Success message displayed');

				// Reset form
				form.reset();
				console.log('✅ Form reset');

				// Hide success message after 5 seconds
				setTimeout(() => {
					successMessage.classList.add('hidden');
				}, 5000);
			} catch (error) {
				console.error('❌ Error submitting form:', error);
				const errorMsg = error instanceof Error ? error.message : 'An error occurred while submitting your request.';
				console.error('   Error details:', errorMsg);
				errorText.textContent = errorMsg;
				errorMessage.classList.remove('hidden');
			} finally {
				// Re-enable button and restore text
				submitBtn.disabled = false;
				submitText.textContent = 'Submit Application';
				submitIcon.classList.remove('animate-spin');
				console.log('✅ Submission complete');
			}
		});
	} else {
		console.error('❌ ContactForm element not found!');
	}
</script>

