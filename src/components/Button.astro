---
interface Props {
	href?: string;
	variant?: 'primary' | 'secondary' | 'outline' | 'ghost';
	size?: 'sm' | 'md' | 'lg';
	class?: string;
}

const { 
	href, 
	variant = 'primary', 
	size = 'md',
	class: className,
	...rest 
} = Astro.props;

const variants = {
	primary: 'bg-primary text-white hover:bg-accent',
	secondary: 'bg-bg-light text-primary hover:bg-gray-200',
	outline: 'border-2 border-primary text-primary hover:bg-primary hover:text-white',
	ghost: 'text-primary hover:bg-gray-100'
};

const sizes = {
	sm: 'px-4 py-2 text-sm',
	md: 'px-6 py-3 text-base',
	lg: 'px-8 py-4 text-lg'
};

const Element = href ? 'a' : 'button';
---

<Element
	href={href}
	class:list={[
		'inline-flex items-center justify-center font-semibold transition-all duration-200 rounded-lg cursor-pointer whitespace-nowrap',
		variants[variant],
		sizes[size],
		className
	]}
	{...rest}
>
	<slot />
</Element>
