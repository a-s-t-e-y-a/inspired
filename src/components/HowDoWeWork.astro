---
import Button from "./Button.astro";

const steps = [
  {
    step: "Step 1",
    title: "Share Your Case",
    description: "Send us your medical reports. Our doctors will review them for free and give you an expert second opinion within 24 hours.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><rect x="8" y="2" width="8" height="4" rx="1" ry="1"/><path d="M12 11h4"/><path d="M12 16h4"/><path d="M8 11h.01"/><path d="M8 16h.01"/></svg>`
  },
  {
    step: "Step 2",
    title: "Get Your Plan",
    description: "We 'tailor' a plan for you, showing the best hospitals, top surgeons, and a clear, all-inclusive price—no hidden fees.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><path d="M9 14l2 2 4-4"/><rect x="8" y="2" width="8" height="4" rx="1" ry="1"/></svg>`
  },
  {
    step: "Step 3",
    title: "We Handle the Travel",
    description: "From your Visa and flights to picking you up at the airport in India, we take care of the paperwork so you can focus on healing.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 15.5l-3.5-3.5a2.12 2.12 0 0 0-3 0l-1.5 1.5-2.5-2.5-3.5 3.5"/><path d="m11.5 11.5 3.5-3.5"/><path d="m11.5 11.5-3.5 3.5"/><path d="m20.5 8.5-3 3"/><path d="M17.8 19.3L16 22l-1.8-2.7"/><path d="M2 17l.6-1.3C3.5 14.2 5 13 6.6 13c1.6 0 3.2 1.2 4.1 2.7l.6 1.3"/><path d="m8 13.5-2-2"/></svg>`
  },
  {
    step: "Step 4",
    title: "Treatment & Recovery",
    description: "Get treated at a world-class hospital. We stay by your side until you are healthy, happy, and ready to fly back home.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.5 3.8 17 5 19 5a1 1 0 0 1 1 1z"/><path d="M12 9v6"/><path d="M9 12h6"/></svg>`
  }
];

// Special Airplane Icon Fix for Step 3
steps[2].icon = `<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17.8 19.2L16 11l3.5-3.5C21 6 21.5 4 21 3c-1-.5-3 0-4.5 1.5L13 8 4.8 6.2c-.5-.1-.9.1-1.1.5l-.3.5c-.2.5-.1 1 .3 1.3L9 12l-2 3H4l-1 1 3 2 2 3 1-1v-3l3-2 3.5 5.3c.3.4.8.5 1.3.3l.5-.2c.4-.3.6-.7.5-1.2z"/></svg>`;
---

<section class="bg-[#DAE9FF] py-24 px-4 md:px-20">
	<div class="w-full max-w-[1600px] mx-auto">
		<h2 class="text-[32px] md:text-[40px] font-[350] text-[#000000] mb-16 tracking-tight px-4 md:px-0">
			How do we work?
		</h2>

		<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-8 mb-16">
			{steps.map((item) => (
				<div class="flex flex-col items-center text-center px-4">
					<!-- Step Icon Circle -->
					<div class="w-40 h-40 md:w-48 md:h-48 bg-[#1647DF] rounded-full flex items-center justify-center text-white mb-8 shadow-lg transition-transform hover:scale-105 duration-300">
						<div class="flex flex-col items-center">
							<Fragment set:html={item.icon} />
						</div>
					</div>
					
					<!-- Content -->
					<div class="max-w-[320px]">
						<h3 class="text-black text-base md:text-lg font-semibold mb-3 tracking-wide">
							{item.step}: {item.title}
						</h3>
						<p class="text-gray-600 text-[14px] md:text-[15px] leading-relaxed font-[300]">
							{item.description}
						</p>
					</div>
				</div>
			))}
		</div>

		<div class="flex justify-center mt-12 pb-4">
			<Button variant="primary" size="lg" class="bg-[#1647DF] px-12 py-4 rounded-lg font-semibold text-base">
				Book Free Consultation
			</Button>
		</div>
	</div>
</section>
