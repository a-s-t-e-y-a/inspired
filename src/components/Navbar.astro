---
import Button from "./Button.astro";
import SearchBar from "./SearchBar.astro";
---

<nav class="bg-white py-5 shadow-md">
	<div class="container px-4 md:px-20">
		<!-- Top Row: Toggle and Logo -->
		<div
			class="grid grid-cols-3 lg:flex lg:flex-nowrap justify-between items-center gap-4 lg:gap-8 mb-4 lg:mb-0"
		>
			<div class="flex items-center justify-start lg:hidden">
				<button
					id="menu-toggle"
					class="p-2 hover:bg-gray-100 rounded-lg transition-colors focus:outline-none focus:ring-2 focus:ring-primary/50 text-black"
					aria-label="Toggle menu"
				>
					<svg
						xmlns="http://www.w3.org/2000/svg"
						width="24"
						height="24"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
						><line x1="4" x2="20" y1="12" y2="12"></line><line
							x1="4"
							x2="20"
							y1="6"
							y2="6"></line><line x1="4" x2="20" y1="18" y2="18"
						></line></svg
					>
				</button>
			</div>

			<div class="flex items-center justify-center lg:justify-start">
				<a href="/" class="shrink-0 flex items-center">
					<img
						src="/maditailarLogo.png"
						alt="Meditailor Logo"
						class="h-[75px] md:h-[80px] w-auto transition-all"
					/>
				</a>
			</div>

			<div class="lg:hidden"></div>

			<!-- Search Bar: Centered on desktop, full row below on mobile -->
			<div class="hidden lg:flex lg:flex-grow lg:justify-center">
				<!-- <SearchBar /> -->
			</div>

			<!-- Desktop Nav items -->
			<div
				id="nav-content"
				class="hidden lg:flex items-center gap-6 xl:gap-10 text-md font-medium whitespace-nowrap"
			>
				<a
					href="/"
					class="text-black hover:text-primary transition-colors py-2 border-b-2 border-transparent hover:border-primary"
					>Home</a
				>
				<a
					href="/services"
					class="text-black hover:text-primary transition-colors py-2 border-b-2 border-transparent hover:border-primary"
					>Services</a
				>
				<!-- <a
					href="/packages"
					class="text-black hover:text-primary transition-colors py-2 border-b-2 border-transparent hover:border-primary"
					>Packages</a
				> -->
				<a
					href="/about"
					class="text-black hover:text-primary transition-colors py-2 border-b-2 border-transparent hover:border-primary"
					>About Us</a
				>
				<a
					href="/contact"
					class="text-black hover:text-primary transition-colors py-2 border-b-2 border-transparent hover:border-primary"
					>Contact Us</a
				>
			</div>
		</div>

		<!-- Mobile Search Bar: Separate Row -->
		<div class="lg:hidden w-full mt-2">
			<SearchBar />
		</div>
	</div>

	<!-- Mobile Menu Dropdown -->
	<div
		id="mobile-menu"
		class="hidden lg:hidden bg-white px-4 py-6 border-t border-gray-100 mt-3 space-y-4 shadow-xl"
	>
		<a
			href="/"
			class="block text-lg font-light text-black hover:text-primary transition-colors"
			>Home</a
		>
		<a
			href="/services"
			class="block text-lg font-light text-black hover:text-primary transition-colors"
			>Services</a
		>
		<!-- <a
			href="/packages"
			class="block text-lg font-light text-black hover:text-primary transition-colors"
			>Packages</a
		> -->
		<a
			href="/about"
			class="block text-lg font-light text-black hover:text-primary transition-colors"
			>About Us</a
		>
		<a
			href="/contact"
			class="block text-lg font-light text-black hover:text-primary transition-colors"
			>Contact Us</a
		>
	</div>
</nav>

<script>
	const menuToggle = document.getElementById("menu-toggle");
	const mobileMenu = document.getElementById("mobile-menu");

	if (menuToggle && mobileMenu) {
		menuToggle.addEventListener("click", () => {
			mobileMenu.classList.toggle("hidden");
		});
	}
</script>
