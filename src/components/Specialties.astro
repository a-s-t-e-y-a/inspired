---
const specialties = [
	{ 
		title: "Cardiology", 
		icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-heart-pulse"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/><path d="M3.22 12H9.5l.5-1 2 4.5 2-7 1.5 3.5h5.27"/></svg>`,
		description: "Expert heart care and vascular treatments."
	},
	{ 
		title: "Oncology", 
		icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-microscope"><path d="M6 18h8"/><path d="M3 22h18"/><path d="M14 22a7 7 0 1 0-14 0"/><path d="M9 14h2"/><path d="M9 12a2 2 0 1 1-4 0V7a2 2 0 1 1 4 0v5Z"/><path d="M12 7a4 4 0 0 1 8 0v5"/><path d="M11 12h1"/><path d="M14 12h1"/><path d="M15 9h2"/></svg>`,
		description: "Advanced cancer therapies and precision medicine."
	},
	{ 
		title: "Orthopedics", 
		icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-bone"><path d="M17 10c.7-.7 1.69-1 2.5-1a2.5 2.5 0 1 1 0 5c-.81 0-1.79-.3-2.5-1"/><path d="M14 7c.7-.7 1-1.69 1-2.5a2.5 2.5 0 1 0-5 0c0 .81.3 1.79 1 2.5"/><path d="m7 10-3-3"/><path d="m17 10 3 3"/><path d="M7 10c-.7-.7-1-1.69-1-2.5a2.5 2.5 0 1 0-5 0c0 .81.3 1.79 1 2.5"/><path d="M7 14c-.7.7-1.69 1-2.5 1a2.5 2.5 0 1 1 0-5c.81 0 1.79.3 2.5.1"/><path d="m14 17 3 3"/><path d="m7 14-3 3"/><path d="m14 17c-.7.7-1 1.69-1 2.5a2.5 2.5 0 1 0 5 0c0-.81-.3-1.79-1-2.5"/><path d="M10 7 7 10"/><path d="m14 17 3-3"/></svg>`,
		description: "Specialized joint replacements and spine surgery."
	},
	{ 
		title: "Neurology", 
		icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-brain"><path d="M9.5 2a5 5 0 0 1 0 10"/><path d="M14.5 2a5 5 0 0 0 0 10"/><path d="M9.5 22a5 5 0 0 0 0-10"/><path d="M14.5 22a5 5 0 0 1 0-10"/><path d="M2 9.5a5 5 0 0 1 10 0"/><path d="M2 14.5a5 5 0 0 0 10 0"/><path d="M22 9.5a5 5 0 0 0-10 0"/><path d="M22 14.5a5 5 0 0 1-10 0"/></svg>`,
		description: "Comprehensive care for neurological conditions."
	},
	{ 
		title: "Gastroenterology", 
		icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-stethosocpe"><path d="M4.8 2.3A.3.3 0 1 0 5 2a2 2 0 0 0-2 2v12a6 6 0 0 0 6 6 6 6 0 0 0 6-6V4a2 2 0 0 0-2-2 .3.3 0 1 0 .2.3"/><path d="M9 16V5a2 2 0 0 1 2-2h1a2 2 0 0 1 2 2v11"/><path d="M6 16h6"/><path d="M2 16h10"/></svg>`,
		description: "Digestive health and liver specialists."
	},
	{ 
		title: "Urology", 
		icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-pipette"><path d="m14 2 6 6"/><path d="m14.5 6.5 3 3"/><path d="m2 22 3-3"/><path d="M9.5 14.5 16 8l3 3-6.5 6.5Z"/><path d="m1.5 22.5 3-3"/></svg>`,
		description: "Advanced urological and kidney care."
	},
	{ 
		title: "Fertility (IVF)", 
		icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-baby"><path d="M9 12h.01"/><path d="M15 12h.01"/><path d="M10 16c.5.3 1.2.5 2 .5s1.5-.2 2-.5"/><path d="M12 2a5 5 0 0 0-5 5v2.8a5 5 0 0 0-2.4 8c1.3 1.1 3 1.8 4.9 2.1l-.5 3.1h6l-.5-3.1c1.9-.3 3.6-1 4.9-2.1a5 5 0 0 0-2.4-8V7a5 5 0 0 0-5-5Z"/></svg>`,
		description: "Expert reproductive medicine and IVF support."
	},
	{ 
		title: "Organ Transplant", 
		icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-activity"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>`,
		description: "World-class kidney, liver, and heart transplants."
	}
];
---

<section class="bg-white py-12 md:py-20 px-2 md:px-20 lg:pl-[calc((100%-1200px)/2+4rem)] xl:pl-[calc((100%-1600px)/2+5rem)] xl:pr-[calc((100%-1600px)/2+5rem)]">
	<div class="w-full max-w-[1600px] mx-auto">
		<div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-12 px-4 md:px-0">
			<div class="max-w-[700px]">
				<h2 class="text-[32px] md:text-[40px] font-[300] text-black mb-4 tracking-tight">Our Medical Specialties</h2>
				<p class="text-gray-500 text-lg font-[300]">Access top-tier medical experts across specialized fields, providing innovative treatments for complex health journeys.</p>
			</div>
			<a href="/services" class="hidden md:flex items-center gap-2 text-primary font-semibold hover:gap-3 transition-all">
				View All Specialities
				<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
			</a>
		</div>

		<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
			{specialties.map((specialty) => (
				<div class="group bg-white border border-gray-100 p-8 rounded-3xl hover:border-primary/20 hover:shadow-xl hover:-translate-y-2 transition-all duration-300">
					<div class="w-16 h-16 bg-bg-light rounded-2xl flex items-center justify-center text-primary mb-6 group-hover:scale-110 transition-transform duration-300">
						<Fragment set:html={specialty.icon} />
					</div>
					<h3 class="text-xl font-[500] text-black mb-3">{specialty.title}</h3>
					<p class="text-gray-500 font-[300] text-sm leading-relaxed mb-6">
						{specialty.description}
					</p>
					<a href={`/services/${specialty.title.toLowerCase().replace(/\s+/g, '-')}`} class="inline-flex items-center gap-2 text-primary text-sm font-semibold hover:gap-3 transition-all">
						Read Details
						<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
					</a>
				</div>
			))}
		</div>

		<div class="mt-12 md:hidden">
			<a href="/services" class="flex items-center justify-center gap-2 text-primary font-semibold py-4 border border-primary/20 rounded-2xl bg-bg-light/30">
				View All Specialities
				<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
			</a>
		</div>
	</div>
</section>
