---
import Layout from "../layouts/Layout.astro";
import Button from "../components/Button.astro";

const mapSrc =
	"https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3806.4270007539367!2d78.39223627474942!3d17.43926508345678!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3bcb9193a2bfabab%3A0xd2193f2d37b866aa!2sTrendz%20aspire!5e0!3m2!1sen!2sin!4v1775822961443!5m2!1sen!2sin";
---

<Layout title="Contact Us - MediTailor" bodyClass="bg-bg-light">
	<main class="py-12 md:py-20">
		<div class="container max-w-[1400px] mx-auto px-4 md:px-0">
			<!-- Page Heading -->
			<div class="mb-12 md:mb-16">
				<h1
					class="text-[40px] md:text-[52px] font-[300] text-primary mb-4"
				>
					Contact Us
				</h1>
				<p
					class="text-[16px] md:text-[18px] text-gray-600 max-w-[800px] leading-relaxed font-[300]"
				>
					Ready to explore world-class medical tourism? Get in touch
					with our team and we'll help you plan your healthcare
					journey.
				</p>
			</div>

			<!-- Main 2-Column Grid -->
			<div
				class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-stretch"
			>
				<!-- Left Column: Map and Info -->
				<div class="flex flex-col gap-10">
					<!-- Map Section -->
					<div
						class="bg-accent-light p-6 rounded-[2rem] md:rounded-[2.5rem] shadow-xl min-h-[450px] flex flex-col"
					>
						<iframe
							src={mapSrc}
							width="100%"
							height="100%"
							style="border:0;"
							allowfullscreen=""
							loading="lazy"
							referrerpolicy="no-referrer-when-downgrade"
							class="rounded-xl md:rounded-3xl flex-grow shadow-inner"
						></iframe>
					</div>

					<!-- Get in Touch Info Section -->
					<div
						class="bg-accent p-8 md:p-16 rounded-[2rem] md:rounded-[2.5rem] shadow-xl text-black"
					>
						<h2 class="text-[28px] md:text-[32px] font-bold mb-10">
							Get in Touch
						</h2>

						<div class="space-y-8">
							<div class="flex items-start gap-5">
								<div class="bg-black/5 p-3 rounded-xl mt-1">
									<svg
										xmlns="http://www.w3.org/2000/svg"
										width="24"
										height="24"
										viewBox="0 0 24 24"
										fill="none"
										stroke="currentColor"
										stroke-width="2"
										stroke-linecap="round"
										stroke-linejoin="round"
										><path
											d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l2.27-2.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"
										></path></svg
									>
								</div>
								<div>
									<p
										class="font-bold text-sm uppercase opacity-60 tracking-wider mb-1"
									>
										Phone number
									</p>
									<p class="text-xl font-medium">
										+91 8595114141
									</p>
								</div>
							</div>

							<div class="flex items-start gap-5">
								<div class="bg-black/5 p-3 rounded-xl mt-1">
									<svg
										xmlns="http://www.w3.org/2000/svg"
										width="24"
										height="24"
										viewBox="0 0 24 24"
										fill="none"
										stroke="currentColor"
										stroke-width="2"
										stroke-linecap="round"
										stroke-linejoin="round"
										><rect
											width="20"
											height="16"
											x="2"
											y="4"
											rx="2"></rect><path
											d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"
										></path></svg
									>
								</div>
								<div>
									<p
										class="font-bold text-sm uppercase opacity-60 tracking-wider mb-1"
									>
										Email id
									</p>
									<p class="text-xl font-medium">
										info.meditailor@gmail.com
									</p>
								</div>
							</div>

							<div class="flex items-start gap-5">
								<div class="bg-black/5 p-3 rounded-xl mt-1">
									<svg
										xmlns="http://www.w3.org/2000/svg"
										width="24"
										height="24"
										viewBox="0 0 24 24"
										fill="none"
										stroke="currentColor"
										stroke-width="2"
										stroke-linecap="round"
										stroke-linejoin="round"
										><path
											d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"
										></path><circle cx="12" cy="10" r="3"
										></circle></svg
									>
								</div>
								<div>
									<p
										class="font-bold text-sm uppercase opacity-60 tracking-wider mb-1"
									>
										Address
									</p>
									<p
										class="text-xl font-medium leading-[1.4]"
									>
										Kavuri Hills, Trendz Aspire, Madhapur,<br
										/>
										Hitech City, Hyderabad,<br />
										Telangana, India
									</p>
								</div>
							</div>
						</div>

						<div
							class="mt-16 pt-10 border-t border-black/10 grid grid-cols-1 sm:grid-cols-2 gap-8"
						>
							<div>
								<p
									class="font-bold text-sm uppercase opacity-60 tracking-wider mb-1"
								>
									Director
								</p>
								<p class="text-xl font-medium leading-tight">
									Karan Singhal
								</p>
							</div>
							<div>
								<p
									class="font-bold text-sm uppercase opacity-60 tracking-wider mb-1"
								>
									Co-founder
								</p>
								<p class="text-xl font-medium leading-tight">
									Rakhi Singhal
								</p>
							</div>
						</div>
					</div>
				</div>

				<!-- Right Column: Contact Form Section -->
				<div
					class="bg-primary p-8 md:p-20 rounded-[2rem] md:rounded-[2.5rem] shadow-xl text-white flex flex-col justify-center"
				>
					<h2
						class="text-[32px] md:text-[42px] font-[400] mb-12 text-center tracking-tight"
					>
						Need Help?
					</h2>

					<form class="space-y-8">
						<div class="space-y-2">
							<label
								class="block text-sm font-medium opacity-90 ml-1"
								>Patient Full Name</label
							>
							<input
								type="text"
								placeholder="Enter patient full name"
								class="w-full bg-white text-black px-6 py-4 rounded-xl outline-none focus:ring-2 focus:ring-accent-light transition-all placeholder:text-gray-400"
							/>
						</div>

						<div class="space-y-2">
							<label
								class="block text-sm font-medium opacity-90 ml-1"
								>Select Country</label
							>
							<div class="relative">
								<select
									class="w-full bg-white text-black px-6 py-4 rounded-xl outline-none focus:ring-2 focus:ring-accent-light transition-all appearance-none cursor-pointer"
								>
									<option value="">Select your country</option
									>
									<option value="NG">Nigeria</option>
									<option value="ET">Ethiopia</option>
									<option value="BD">Bangladesh</option>
									<option value="US">United States</option>
									<option value="GB">United Kingdom</option>
								</select>
								<div
									class="absolute inset-y-0 right-4 flex items-center pointer-events-none text-gray-400"
								>
									<svg
										xmlns="http://www.w3.org/2000/svg"
										width="20"
										height="20"
										viewBox="0 0 24 24"
										fill="none"
										stroke="currentColor"
										stroke-width="2"
										stroke-linecap="round"
										stroke-linejoin="round"
										><path d="m6 9 6 6 6-6"></path></svg
									>
								</div>
							</div>
						</div>

						<div class="space-y-2">
							<label
								class="block text-sm font-medium opacity-90 ml-1"
								>Your email id</label
							>
							<input
								type="email"
								placeholder="Enter your email id"
								class="w-full bg-white text-black px-6 py-4 rounded-xl outline-none focus:ring-2 focus:ring-accent-light transition-all placeholder:text-gray-400"
							/>
						</div>

						<div class="space-y-2">
							<label
								class="block text-sm font-medium opacity-90 ml-1"
								>Your Phone number</label
							>
							<div class="flex gap-4">
								<div
									class="bg-white/10 text-white border border-white/20 px-3 md:px-5 py-4 rounded-xl font-bold flex items-center justify-center min-w-[60px] md:min-w-[70px]"
								>
									+91
								</div>
								<input
									type="tel"
									placeholder="Enter phone number"
									class="min-w-0 flex-1 bg-white text-black px-4 md:px-6 py-4 rounded-xl outline-none focus:ring-2 focus:ring-accent-light transition-all placeholder:text-gray-400"
								/>
							</div>
						</div>

						<div class="space-y-2">
							<label
								class="block text-sm font-medium opacity-90 ml-1"
								>Describe your medical condition</label
							>
							<textarea
								placeholder="Describe your medical condition here..."
								rows="5"
								class="w-full bg-white text-black px-6 py-4 rounded-xl outline-none focus:ring-2 focus:ring-accent-light transition-all resize-none placeholder:text-gray-400"
							></textarea>
						</div>

						<div class="pt-6">
							<Button
								variant="outline"
								size="lg"
								class="w-full bg-accent hover:bg-[#00e6a8] text-black py-6 rounded-2xl text-xl shadow-lg transform active:scale-[0.98] transition-all font-bold tracking-wide"
							>
								Submit your query
							</Button>
						</div>
					</form>
				</div>
			</div>
		</div>
	</main>
</Layout>
