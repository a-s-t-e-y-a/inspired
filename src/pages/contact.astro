---
import Layout from "../layouts/Layout.astro";
import Button from "../components/Button.astro";

const mapSrc =
	"https://www.google.com/maps/embed?pb=!1m17!1m12!1m3!1d3722.135674732847!2d77.08074771118972!3d28.72257467988418!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m2!1m1!2zMjjCsDQzJzIxLjMiTiA3N8KwMDQnNjAuMCJF!5e1!3m2!1sen!2sin!4v1777195535005!5m2!1sen!2sin";
---

<Layout title="Contact Us - MediTailor" bodyClass="bg-bg-light">
	<main class="py-12 md:py-20">
		<div class="container max-w-[1400px] mx-auto px-4 md:px-0">
			<!-- Page Heading -->
			<div class="mb-12 md:mb-16">
				<h1
					class="text-[40px] md:text-[52px] font-[300] text-primary mb-4"
				>
					Contact Us
				</h1>
				<p
					class="text-[16px] md:text-[18px] text-gray-600 max-w-[800px] leading-relaxed font-[300]"
				>
					Ready to explore world-class medical tourism? Get in touch
					with our team and we'll help you plan your healthcare
					journey.
				</p>
			</div>

			<!-- Main 2-Column Grid -->
			<div
				class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-stretch"
			>
				<!-- Left Column: Map and Info -->
				<div class="flex flex-col gap-10">
					<!-- Map Section -->
					<div
						class="bg-accent-light p-6 rounded-[2rem] md:rounded-[2.5rem] shadow-xl min-h-[450px] flex flex-col"
					>
						<iframe
							src={mapSrc}
							width="100%"
							height="100%"
							style="border:0;"
							allowfullscreen=""
							loading="lazy"
							referrerpolicy="no-referrer-when-downgrade"
							class="rounded-xl md:rounded-3xl flex-grow shadow-inner"
						></iframe>
					</div>

					<!-- Get in Touch Info Section -->
					<div
						class="bg-accent p-8 md:p-16 rounded-[2rem] md:rounded-[2.5rem] shadow-xl text-black"
					>
						<h2 class="text-[28px] md:text-[32px] font-bold mb-10">
							Get in Touch
						</h2>

						<div class="space-y-8">
							<div class="flex items-start gap-5">
								<div class="bg-black/5 p-3 rounded-xl mt-1">
									<svg
										xmlns="http://www.w3.org/2000/svg"
										width="24"
										height="24"
										viewBox="0 0 24 24"
										fill="none"
										stroke="currentColor"
										stroke-width="2"
										stroke-linecap="round"
										stroke-linejoin="round"
										><path
											d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l2.27-2.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"
										></path></svg
									>
								</div>
								<div>
									<p
										class="font-bold text-sm uppercase opacity-60 tracking-wider mb-1"
									>
										Phone number
									</p>
									<p class="text-xl font-medium">
										+91 8010011200
									</p>
								</div>
							</div>

							<div class="flex items-start gap-5">
								<div class="bg-black/5 p-3 rounded-xl mt-1">
									<svg
										xmlns="http://www.w3.org/2000/svg"
										width="24"
										height="24"
										viewBox="0 0 24 24"
										fill="none"
										stroke="currentColor"
										stroke-width="2"
										stroke-linecap="round"
										stroke-linejoin="round"
										><rect
											width="20"
											height="16"
											x="2"
											y="4"
											rx="2"></rect><path
											d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"
										></path></svg
									>
								</div>
								<div>
									<p
										class="font-bold text-sm uppercase opacity-60 tracking-wider mb-1"
									>
										Email id
									</p>
									<p class="text-xl font-medium">
										sales@puregrein.com
									</p>
								</div>
							</div>

							<div class="flex items-start gap-5">
								<div class="bg-black/5 p-3 rounded-xl mt-1">
									<svg
										xmlns="http://www.w3.org/2000/svg"
										width="24"
										height="24"
										viewBox="0 0 24 24"
										fill="none"
										stroke="currentColor"
										stroke-width="2"
										stroke-linecap="round"
										stroke-linejoin="round"
										><path
											d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"
										></path><circle cx="12" cy="10" r="3"
										></circle></svg
									>
								</div>
								<div>
									<p
										class="font-bold text-sm uppercase opacity-60 tracking-wider mb-1"
									>
										Address
									</p>
									<p
										class="text-xl font-medium leading-[1.4]"
									>
										105, Ground Floor, Pocket-8,<br />
										Sector-23, Rohini,<br />
										New Delhi-110085, India
									</p>
								</div>
							</div>
						</div>

						<div
							class="mt-16 pt-10 border-t border-black/10 grid grid-cols-1 sm:grid-cols-2 gap-8"
						>
							<div>
								<p
									class="font-bold text-sm uppercase opacity-60 tracking-wider mb-1"
								>
									Director
								</p>
								<p class="text-xl font-medium leading-tight">
									Karan Singhal
								</p>
							</div>
							<div>
								<p
									class="font-bold text-sm uppercase opacity-60 tracking-wider mb-1"
								>
									Co-founder
								</p>
								<p class="text-xl font-medium leading-tight">
									Rakhi Singhal
								</p>
							</div>
						</div>
					</div>
				</div>

				<!-- Right Column: Contact Form Section -->
				<div
					class="bg-primary p-8 md:p-20 rounded-[2rem] md:rounded-[2.5rem] shadow-xl text-white flex flex-col justify-center"
				>
					<h2
						class="text-[32px] md:text-[42px] font-[400] mb-12 text-center tracking-tight"
					>
						Need Help?
					</h2>

					<form id="needHelpForm" class="space-y-8">
						<div class="space-y-2">
							<label
								class="block text-sm font-medium opacity-90 ml-1"
								>Patient Full Name</label
							>
							<input
								id="needHelp-fullName"
								name="fullName"
								type="text"
								placeholder="Enter patient full name"
								class="w-full bg-white text-black px-6 py-4 rounded-xl outline-none focus:ring-2 focus:ring-accent-light transition-all placeholder:text-gray-400 invalid:ring-red-500 invalid:ring-2"
							/>
							<p id="needHelp-fullName-error" class="text-red-300 text-sm mt-1 hidden"></p>
						</div>

						<div class="space-y-2">
							<label
								class="block text-sm font-medium opacity-90 ml-1"
								>Select Country</label
							>
							<div class="relative">
								<select
									id="needHelp-country"
									name="country"
									class="w-full bg-white text-black px-6 py-4 rounded-xl outline-none focus:ring-2 focus:ring-accent-light transition-all appearance-none cursor-pointer invalid:ring-red-500 invalid:ring-2"
								>
									<option value="">Select your country</option
									>
									<option value="NG">Nigeria</option>
									<option value="ET">Ethiopia</option>
									<option value="BD">Bangladesh</option>
									<option value="US">United States</option>
									<option value="GB">United Kingdom</option>
								</select>
								<div
									class="absolute inset-y-0 right-4 flex items-center pointer-events-none text-gray-400"
								>
									<svg
										xmlns="http://www.w3.org/2000/svg"
										width="20"
										height="20"
										viewBox="0 0 24 24"
										fill="none"
										stroke="currentColor"
										stroke-width="2"
										stroke-linecap="round"
										stroke-linejoin="round"
										><path d="m6 9 6 6 6-6"></path></svg
									>
								</div>
							</div>
							<p id="needHelp-country-error" class="text-red-300 text-sm mt-1 hidden"></p>
						</div>

						<div class="space-y-2">
							<label
								class="block text-sm font-medium opacity-90 ml-1"
								>Your email id</label
							>
							<input
								id="needHelp-email"
								name="email"
								type="email"
								placeholder="Enter your email id"
								class="w-full bg-white text-black px-6 py-4 rounded-xl outline-none focus:ring-2 focus:ring-accent-light transition-all placeholder:text-gray-400 invalid:ring-red-500 invalid:ring-2"
							/>
							<p id="needHelp-email-error" class="text-red-300 text-sm mt-1 hidden"></p>
						</div>

						<div class="space-y-2">
							<label
								class="block text-sm font-medium opacity-90 ml-1"
								>Your Phone number</label
							>
							<div class="flex gap-4">
								<div
									class="bg-white/10 text-white border border-white/20 px-3 md:px-5 py-4 rounded-xl font-bold flex items-center justify-center min-w-[60px] md:min-w-[70px]"
								>
									+91
								</div>
								<input
									id="needHelp-phone"
									name="phone"
									type="tel"
									placeholder="Enter phone number"
									class="min-w-0 flex-1 bg-white text-black px-4 md:px-6 py-4 rounded-xl outline-none focus:ring-2 focus:ring-accent-light transition-all placeholder:text-gray-400 invalid:ring-red-500 invalid:ring-2"
								/>
							</div>
							<p id="needHelp-phone-error" class="text-red-300 text-sm mt-1 hidden"></p>
						</div>

						<div class="space-y-2">
							<label
								class="block text-sm font-medium opacity-90 ml-1"
								>Describe your medical condition</label
							>
							<textarea
								id="needHelp-medicalCondition"
								name="medicalCondition"
								placeholder="Describe your medical condition here..."
								rows="5"
								class="w-full bg-white text-black px-6 py-4 rounded-xl outline-none focus:ring-2 focus:ring-accent-light transition-all resize-none placeholder:text-gray-400 invalid:ring-red-500 invalid:ring-2"
							></textarea>
							<p id="needHelp-medicalCondition-error" class="text-red-300 text-sm mt-1 hidden"></p>
						</div>

						<div class="space-y-2">
							<label
								class="block text-sm font-medium opacity-90 ml-1"
								>Upload Medical Document (Optional)</label
							>
							<input
								id="needHelp-document"
								name="document"
								type="file"
								accept=".pdf,.png,.jpg,.jpeg,.doc,.docx"
								class="w-full bg-white text-black px-6 py-4 rounded-xl outline-none focus:ring-2 focus:ring-accent-light transition-all file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-primary/10 file:text-primary hover:file:bg-primary/20 placeholder:text-gray-400 cursor-pointer"
							/>
							<p id="needHelp-document-error" class="text-red-300 text-sm mt-1 hidden"></p>
						</div>

						<!-- Status Messages -->
						<div id="needHelp-successMessage" class="hidden bg-green-500/20 border border-green-500 text-green-100 px-4 py-3 rounded-lg text-sm flex items-center gap-2">
							<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg>
							<span>Thank you! Your medical request has been submitted successfully.</span>
						</div>

						<div id="needHelp-errorMessage" class="hidden bg-red-500/20 border border-red-500 text-red-100 px-4 py-3 rounded-lg text-sm flex items-center gap-2">
							<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><line x1="12" x2="12" y1="8" y2="12"></line><line x1="12" x2="12.01" y1="16" y2="16"></line></svg>
							<span id="needHelp-errorText">An error occurred. Please try again.</span>
						</div>

						<div class="pt-6">
							<Button
								id="needHelp-submitBtn"
								variant="outline"
								size="lg"
								type="submit"
								class="w-full bg-accent hover:bg-[#00e6a8] text-black py-6 rounded-2xl text-xl shadow-lg transform active:scale-[0.98] transition-all font-bold tracking-wide disabled:opacity-50 disabled:cursor-not-allowed"
							>
								<span id="needHelp-submitText">Submit your query</span>
							</Button>
						</div>
					</form>
				</div>
			</div>
		</div>
	</main>
</Layout>

<script>
	import { db } from '../utils/supabase';
	import { validateMedicalForm } from '../utils/validation';

	console.log('📋 Need Help form script loaded');

	const form = document.getElementById('needHelpForm') as HTMLFormElement;
	const submitBtn = document.getElementById('needHelp-submitBtn') as HTMLButtonElement;
	const submitText = document.getElementById('needHelp-submitText') as HTMLElement;
	const successMessage = document.getElementById('needHelp-successMessage') as HTMLElement;
	const errorMessage = document.getElementById('needHelp-errorMessage') as HTMLElement;
	const errorText = document.getElementById('needHelp-errorText') as HTMLElement;

	console.log('✅ Need Help form elements found:', { form: !!form, submitBtn: !!submitBtn });

	if (form) {
		form.addEventListener('submit', async (e) => {
			e.preventDefault();
			console.log('📤 Form submit event triggered');

			// Get form values
			const fullNameInput = document.getElementById('needHelp-fullName') as HTMLInputElement;
			const countryInput = document.getElementById('needHelp-country') as HTMLSelectElement;
			const emailInput = document.getElementById('needHelp-email') as HTMLInputElement;
			const phoneInput = document.getElementById('needHelp-phone') as HTMLInputElement;
			const medicalConditionInput = document.getElementById('needHelp-medicalCondition') as HTMLTextAreaElement;
			const documentInput = document.getElementById('needHelp-document') as HTMLInputElement;

			const formData = {
				fullName: fullNameInput.value,
				country: countryInput.value,
				email: emailInput.value,
				phone: phoneInput.value,
				medicalCondition: medicalConditionInput.value,
			};

			console.log('📋 Form data collected:', {
				fullName: formData.fullName,
				country: formData.country,
				email: formData.email,
				phone: formData.phone,
				medicalCondition: formData.medicalCondition.substring(0, 100) + '...',
				hasDocument: documentInput.files && documentInput.files.length > 0
			});

			// Clear previous messages
			successMessage.classList.add('hidden');
			errorMessage.classList.add('hidden');

			// Validate form
			console.log('🔍 Validating medical form data...');
			const validation = validateMedicalForm(formData);
			console.log('✅ Validation result:', { isValid: validation.isValid, errors: validation.errors });

			if (!validation.isValid) {
				console.log('❌ Validation failed. Displaying errors...');
				// Display errors
				validation.errors.forEach((error) => {
					console.log(`   - ${error.field}: ${error.message}`);
					const errorElement = document.getElementById(`needHelp-${error.field}-error`) as HTMLElement;
					if (errorElement) {
						errorElement.textContent = error.message;
						errorElement.classList.remove('hidden');
					}
				});
				return;
			}

			console.log('✅ Validation passed!');

			// Clear error messages
			document.querySelectorAll('[id^="needHelp-"][id$="-error"]').forEach((el) => {
				el.classList.add('hidden');
			});

			// Disable button and show loading state
			submitBtn.disabled = true;
			submitText.textContent = 'Submitting...';
			console.log('⏳ Submission started, button disabled');

			try {
				let documentUrl = undefined;
				
				// Handle file upload if present
				if (documentInput && documentInput.files && documentInput.files.length > 0) {
					console.log('📄 Uploading document first...');
					const file = documentInput.files[0];
					
					// Basic file size check (< 5MB)
					if (file.size > 5 * 1024 * 1024) {
						throw new Error('File size exceeds 5MB limit. Please upload a smaller file.');
					}
					
					submitText.textContent = 'Uploading Document...';
					documentUrl = await db.uploadMedicalDocument(file);
				}

				// Step 1: Insert contact into Supabase
				console.log('🚀 Step 1/2: Calling db.insertContact...');
				submitText.textContent = 'Saving Details...';
				const contact = await db.insertContact({
					full_name: formData.fullName,
					country: formData.country,
					email: formData.email,
					phone: formData.phone,
					source: 'need_help',
				});

				console.log('✅ Step 1 complete: Contact created with ID:', contact.id);
				console.log('   Full contact:', contact);

				// Step 2: Insert medical request
				console.log('🚀 Step 2/2: Calling db.insertMedicalRequest...');
				const medicalRequest = await db.insertMedicalRequest({
					contact_id: contact.id,
					medical_condition: formData.medicalCondition,
					document_url: documentUrl,
				});

				console.log('✅ Step 2 complete: Medical request submitted with ID:', medicalRequest.id);
				console.log('   Full medical request:', medicalRequest);

				// Show success message
				successMessage.classList.remove('hidden');
				console.log('✅ Success message displayed');

				// Reset form
				form.reset();
				console.log('✅ Form reset');

				// Hide success message after 5 seconds
				setTimeout(() => {
					successMessage.classList.add('hidden');
				}, 5000);
			} catch (error) {
				console.error('❌ Error submitting form:', error);
				const errorMsg = error instanceof Error ? error.message : 'An error occurred while submitting your request.';
				console.error('   Error details:', errorMsg);
				errorText.textContent = errorMsg;
				errorMessage.classList.remove('hidden');
			} finally {
				// Re-enable button and restore text
				submitBtn.disabled = false;
				submitText.textContent = 'Submit your query';
				console.log('✅ Submission complete');
			}
		});
	} else {
		console.error('❌ Need Help form element not found!');
	}
</script>

